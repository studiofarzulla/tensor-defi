# Tensor DeFi Environment Configuration

# API Keys (optional - most data sources are public)
# BINANCE_API_KEY=your_key_here
# BINANCE_SECRET=your_secret_here
# COINBASE_API_KEY=your_key_here
# COINBASE_SECRET=your_secret_here

# The Graph API (public endpoint, no key needed for basic queries)
# THEGRAPH_API_KEY=your_key_here  # Only needed for high rate limits

# Data Storage
DATA_DIR=./data
OUTPUTS_DIR=./outputs

# Computation Settings
TENSORLY_BACKEND=numpy  # Options: numpy, pytorch, jax
N_JOBS=-1  # Parallel jobs (-1 = all cores)

# Logging
LOG_LEVEL=INFO
